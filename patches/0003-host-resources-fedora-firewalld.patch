@@ -49,15 +47,53 @@
   create_bridges=1
 fi
 
-# Newer distros prefer nft, but broute is not supported, so use
-# the legacy ebtables instead
-ebtables=$(which ebtables-legacy)
-# If there's no ebtables-legacy, it's probably an older distro,
-# and ebtables should support broute directly
-ebtables=${ebtables:-ebtables}
-# Similarly for iptables
-iptables=$(which iptables-legacy)
-iptables=${iptables:-iptables}
+# Fedora keeps firewalld running by default. Use the direct interface so
+# cuttlefish can install the same NAT and bridge-filter rules as Debian
+# without bypassing firewalld. If firewalld isn't available, keep the
+# service alive so slirp launches still work, but warn that bridge/tap
+# networking is degraded until firewalld is restored.
+firewall_cmd=$(command -v firewall-cmd 2>/dev/null || echo firewall-cmd)
+warned_firewalld_persistence=0
+warned_firewalld_runtime=0
+
+firewalld_direct_add_rule() {
+    "${firewall_cmd}" --quiet --direct --add-rule "$@" 2>/dev/null || {
+        if [ "${warned_firewalld_runtime}" != "1" ]; then
+            echo "WARNING: failed to install cuttlefish firewalld rules; bridge/tap networking may be unavailable until firewalld is running again, but slirp mode can still be used" >&2
+            warned_firewalld_runtime=1
+        fi
+        return 0
+    }
+    "${firewall_cmd}" --quiet --permanent --direct --add-rule "$@" 2>/dev/null || {
+        if [ "${warned_firewalld_persistence}" != "1" ]; then
+            echo "WARNING: failed to persist cuttlefish firewalld rules; a firewalld reload will require restarting cuttlefish-host-resources" >&2
+            warned_firewalld_persistence=1
+        fi
+    }
+}
+
+firewalld_direct_remove_rule() {
+    "${firewall_cmd}" --quiet --direct --remove-rule "$@" 2>/dev/null || true
+    "${firewall_cmd}" --quiet --permanent --direct --remove-rule "$@" 2>/dev/null || true
+}
+
+add_masquerade_rule() {
+    network="${1}"
+    firewalld_direct_add_rule ipv4 nat POSTROUTING 0 -s "${network}" -j MASQUERADE
+}
+
+remove_masquerade_rule() {
+    network="${1}"
+    firewalld_direct_remove_rule ipv4 nat POSTROUTING 0 -s "${network}" -j MASQUERADE
+}
+
+add_bridge_filter_rules() {
+    tap="${1}"
+    protocol="${2}"
+    firewalld_direct_add_rule eb broute BROUTING 0 -p "${protocol}" --in-if "${tap}" -j DROP
+    firewalld_direct_add_rule eb filter FORWARD 0 -p "${protocol}" --out-if "${tap}" -j DROP
+}
+
+remove_bridge_filter_rules() {
+    tap="${1}"
+    protocol="${2}"
+    firewalld_direct_remove_rule eb filter FORWARD 0 -p "${protocol}" --out-if "${tap}" -j DROP
+    firewalld_direct_remove_rule eb broute BROUTING 0 -p "${protocol}" --in-if "${tap}" -j DROP
+}
 
 # Make sure these directories exist, since they are used multiple times
 mkdir -p /run /var/run
