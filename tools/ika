#!/usr/bin/bash

set -euo pipefail

exec 3>&1

PACKAGED_CVD_HOST_OUT="/usr/lib/cuttlefish-common"
DEFAULT_CVD_PRODUCT_OUT="/usr/share/cuttlefish-common/lineageos"
PACKAGED_SCRCPY_BIN="/usr/lib/cuttlefish-common/bin/scrcpy"
PACKAGED_SCRCPY_SERVER="/usr/lib/cuttlefish-common/share/scrcpy/scrcpy-server"
SCRCPY_ICON_DIR_DEFAULT="/usr/lib/cuttlefish-common/share/icons/hicolor/256x256/apps"

count_performance_cores() {
  local max_cap
  max_cap="$(cat /sys/devices/system/cpu/cpu*/cpu_capacity 2>/dev/null | sort -n | tail -1)"
  [[ -z "${max_cap}" ]] && { echo 0; return; }
  grep -hxF "${max_cap}" /sys/devices/system/cpu/cpu*/cpu_capacity 2>/dev/null | wc -l
}

# ============================================================================
# Compute Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
declare -A CVD_COMPUTE_DEFAULTS=(
  [cpus]="$(count_performance_cores)"
  [memory_mb]="4096"
  [prefer_performance_cores]="true"
  [enable_bootanimation]="false"
)

# ============================================================================
# GPU Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
declare -A CVD_GPU_DEFAULTS=(
  [gpu_mode]="gfxstream"
  [gpu_vhost_user_mode]="off"
  [enable_gpu_udmabuf]="true"
  [use_cvdalloc]="true"
)

# ============================================================================
# Network Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
declare -A CVD_NETWORK_DEFAULTS=(
  [vhost_net]="true"
  [vhost_user_vsock]="false"
  [enable_wifi]="false"
  [enable_modem_simulator]="false"
  [enable_host_uwb]="false"
  [netsim_bt]="true"
  [netsim_uwb]="false"
)

# ============================================================================
# Display Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
#declare -A CVD_DISPLAY_DEFAULTS=(
#  [x_res]="1728"
#  [y_res]="1006"
#)

# ============================================================================
# Reporting Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
declare -A CVD_REPORT_DEFAULTS=(
  [report_anonymous_usage_stats]="n"
)

# ============================================================================
# Wi-Fi Auto-Connect Configuration Defaults (internal use only)
# ============================================================================
declare -A CVD_WIFI_DEFAULTS=(
  [wifi_auto_connect]="true"
  [wifi_auto_ssid]="VirtWifi"
  [wifi_auto_security]="open"
  [wifi_auto_passphrase]=""
)

# ============================================================================
# Boot & Logging Configuration Defaults (internal use only)
# ============================================================================
declare -A CVD_BOOT_DEFAULTS=(
  [boot_message]="VIRTUAL_DEVICE_BOOT_COMPLETED"
  [boot_timeout_sec]="60"
)

# ============================================================================
# Overlay Configuration Defaults (internal use only)
# ============================================================================
declare -A CVD_OVERLAY_DEFAULTS=(
  [use_overlay]="true"
  [use_sdcard]="false"
)

# Convenience variables
CVD_GPU_MODE="${CVD_GPU_DEFAULTS[gpu_mode]}"
CVD_ENABLE_WIFI="${CVD_NETWORK_DEFAULTS[enable_wifi]}"
CVD_WIFI_AUTO_CONNECT="${CVD_WIFI_DEFAULTS[wifi_auto_connect]}"
CVD_WIFI_AUTO_SSID="${CVD_WIFI_DEFAULTS[wifi_auto_ssid]}"
CVD_WIFI_AUTO_SECURITY="${CVD_WIFI_DEFAULTS[wifi_auto_security]}"
CVD_WIFI_AUTO_PASSPHRASE="${CVD_WIFI_DEFAULTS[wifi_auto_passphrase]}"
: "${CVD_BOOT_MESSAGE:=${CVD_BOOT_DEFAULTS[boot_message]}}"
: "${CVD_BOOT_TIMEOUT_SEC:=${CVD_BOOT_DEFAULTS[boot_timeout_sec]}}"

mkdir -p "${HOME}/.local/ika"
START_LOG_FILE="${HOME}/.local/ika/ikastart.log"

# ============================================================================
# Environment Paths
# ============================================================================
: "${CVD_HOST_OUT:=${PACKAGED_CVD_HOST_OUT}}"
: "${CVD_PRODUCT_OUT:=${DEFAULT_CVD_PRODUCT_OUT}}"
: "${CVD_HOME_DIR:=${HOME}/.local/ika}"
CVD_BIN="${CVD_HOST_OUT}/bin/cvd_internal_start"
CVD_CLI_BIN="${CVD_HOST_OUT}/bin/cvd"
CVD_STOP_BIN="${CVD_HOST_OUT}/bin/cvd_internal_stop"
CVD_INSTANCE_DIR="${CVD_HOME_DIR}/cuttlefish/instances/cvd-1"
CVD_LAUNCHER_LOG="${CVD_INSTANCE_DIR}/logs/launcher.log"
CVD_CONFIG_PATH="${CVD_INSTANCE_DIR}/cuttlefish_config.json"
SCRCPY_BIN="${PACKAGED_SCRCPY_BIN}"
SCRCPY_SERVER_PATH_OVERRIDE=""
if [[ -f "${PACKAGED_SCRCPY_SERVER}" ]]; then
  SCRCPY_SERVER_PATH_OVERRIDE="${PACKAGED_SCRCPY_SERVER}"
fi
SCRCPY_FLEX_DISPLAY_FLAG="--flex-display=192"

CVD_PROCESS_REGEX='(^|/)(cvd_internal_start|launch_cvd|run_cvd|crosvm|process_restarter|socket_vsock_proxy|wmediumd|webRTC)([[:space:]]|$)'

SCRIPT_NAME="$(basename "$0")"

log() {
  printf '[%s] %s\n' "${SCRIPT_NAME}" "$*" >&2
}

die() {
  log "error: $*"
  if [[ -n "${CONSOLE_FAILURE_MESSAGE:-}" ]]; then
    printf '%s\n' "${CONSOLE_FAILURE_MESSAGE}" >&3
  fi
  exit 1
}

respond() {
  printf '%s\n' "$*"
}

respond_console() {
  printf '%s\n' "$*" >&3
}

parse_start_options() {
  local -n fullscreen_mode_ref="$1"
  local -n start_args_ref="$2"
  shift 2

  fullscreen_mode_ref="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--fullscreen)
        fullscreen_mode_ref="true"
        shift
        ;;
      *)
        start_args_ref+=("$1")
        shift
        ;;
    esac
  done
}

configure_scrcpy_flex_display_flag() {
  local scrcpy_flex_display="$1"

  if [[ -n "${scrcpy_flex_display}" ]]; then
    SCRCPY_FLEX_DISPLAY_FLAG="--flex-display=${scrcpy_flex_display}"
  else
    SCRCPY_FLEX_DISPLAY_FLAG=""
  fi
}

console_notify() {
  local action="$1"
  local elapsed_sec="$2"
  printf 'Android virtual device %s in %ss.\n' "${action}" "${elapsed_sec}" >&3
}

run_timed_operation() {
  local action="$1"
  shift

  local start_epoch
  local elapsed_sec

  start_epoch="$(date +%s)"
  "$@"
  elapsed_sec="$(( $(date +%s) - start_epoch ))"

  console_notify "${action}" "${elapsed_sec}"
}

redirect_start_logs() {
  mkdir -p "$(dirname "${START_LOG_FILE}")"
  : > "${START_LOG_FILE}"
  exec >"${START_LOG_FILE}" 2>&1
}

usage() {
  local output_fd="${1:-1}"
  cat >&"${output_fd}" <<EOF

Usage:

  ${SCRIPT_NAME} start [-f|--fullscreen] [--setting=arg] ...
  ${SCRIPT_NAME} stop
  ${SCRIPT_NAME} restart [-f|--fullscreen] ...
  ${SCRIPT_NAME} reset [Delete everything and start fresh]

Example:

  ${SCRIPT_NAME} start --cpus=2 --memory_mb=2048 --flex-display=240 --fullscreen

EOF
}

shell_join() {
  local joined
  printf -v joined '%q ' "$@"
  printf '%s' "${joined% }"
}

latest_launcher_log_message() {
  local launcher_log="$1"
  local min_mtime="$2"
  local pattern="$3"
  local log_mtime

  [[ -f "${launcher_log}" ]] || return 1

  log_mtime="$(stat -c '%Y' "${launcher_log}" 2>/dev/null || echo 0)"
  [[ "${log_mtime}" -ge "${min_mtime}" ]] || return 1

  grep -F "${pattern}" "${launcher_log}" | tail -n 1 || true
}

maybe_respond_crosvm_command() {
  local launcher_log="$1"
  local min_mtime="$2"
  local line
  local command

  line="$(latest_launcher_log_message "${launcher_log}" "${min_mtime}" "crosvm launch command:")"
  [[ -n "${line}" ]] || return 1

  command="${line#*"crosvm launch command: "}"
  respond "[${SCRIPT_NAME}] crosvm launch command: ${command}"
  return 0
}

emit_launch_command() {
  local launch_command

  launch_command="$(
    shell_join \
      env \
      "HOME=${CVD_HOME_DIR}" \
      "ANDROID_HOST_OUT=${CVD_HOST_OUT}" \
      "ANDROID_SOONG_HOST_OUT=${CVD_HOST_OUT}" \
      "ANDROID_PRODUCT_OUT=${CVD_PRODUCT_OUT}" \
      "${CVD_BIN}" \
      "$@"
  )"

  log "launch command: cd $(printf '%q' "${CVD_PRODUCT_OUT}") && ${launch_command}"
}

flag_value() {
  local flag="$1"
  local default_value="$2"
  shift 2
  local value="${default_value}"
  local arg

  for arg in "$@"; do
    case "${arg}" in
      "--${flag}="*|"-${flag}="*)
        value="${arg#*=}"
        ;;
      "--${flag}"|"-${flag}")
        value="true"
        ;;
    esac
  done

  printf '%s\n' "${value}"
}

scrcpy_flex_display_value() {
  local value="192"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --flex-display=*)
        value="${1#*=}"
        shift
        ;;
      --flex-display)
        shift
        [[ $# -gt 0 ]] || die "--flex-display requires a value"
        value="$1"
        shift
        ;;
      *)
        shift
        ;;
    esac
  done

  printf '%s\n' "${value}"
}

append_cvd_args() {
  local -n args_array="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --flex-display=*)
        shift
        ;;
      --flex-display)
        shift
        [[ $# -gt 0 ]] || die "--flex-display requires a value"
        shift
        ;;
      *)
        args_array+=("$1")
        shift
        ;;
    esac
  done
}

require_executable() {
  local path="$1"
  local label="$2"
  [[ -x "${path}" ]] || die "${label} not found or not executable: ${path}"
}

apply_default_args() {
  local -n config_map="$1"
  local -n args_array="$2"
  shift 2
  local key value

  for key in "${!config_map[@]}"; do
    if ! user_supplied_flag "${key}" "$@"; then
      value="${config_map[${key}]}"
      # Handle special case for report_anonymous_usage_stats which uses single dash
      if [[ "${key}" == "report_anonymous_usage_stats" ]]; then
        args_array+=("-${key}=${value}")
      else
        args_array+=("--${key}=${value}")
      fi
    fi
  done
}

run_with_cvd_env() {
  local config_path=""
  local -a env_args=(
    "HOME=${CVD_HOME_DIR}"
    "ANDROID_HOST_OUT=${CVD_HOST_OUT}"
    "ANDROID_SOONG_HOST_OUT=${CVD_HOST_OUT}"
    "ANDROID_PRODUCT_OUT=${CVD_PRODUCT_OUT}"
  )

  if [[ "${1:-}" == "--config" ]]; then
    config_path="${2:-}"
    shift 2
    env_args+=("CUTTLEFISH_CONFIG_FILE=${config_path}")
  fi

  env "${env_args[@]}" "$@"
}

has_session_group() {
  id -nG | tr ' ' '\n' | grep -Fxq "$1"
}

has_configured_group() {
  id -nG "${USER}" | tr ' ' '\n' | grep -Fxq "$1"
}

check_required_groups() {
  local -a required_groups=(kvm video render cvdnetwork)
  local -a missing_groups=()
  local -a inactive_groups=()
  local -a add_groups=()
  local group

  for group in "${required_groups[@]}"; do
    if getent group "${group}" >/dev/null 2>&1 && ! has_session_group "${group}"; then
      missing_groups+=("${group}")
      if has_configured_group "${group}"; then
        inactive_groups+=("${group}")
      else
        add_groups+=("${group}")
      fi
    fi
  done

  if [[ "${#missing_groups[@]}" -eq 0 ]]; then
    return 0
  fi

  cat <<EOF
[${SCRIPT_NAME}] error: current shell is missing required groups.

Active groups:
  $(id -nG)

Missing groups:
  ${missing_groups[*]}

EOF

  if [[ "${#add_groups[@]}" -gt 0 ]]; then
    cat <<EOF
To add the missing account membership:
  pkexec /usr/libexec/cuttlefish/cuttlefish-add-user-to-groups

EOF
  fi

  if [[ "${#inactive_groups[@]}" -gt 0 ]]; then
    cat <<EOF
Configured on the account but not active in this login session:
  ${inactive_groups[*]}

EOF
  fi

  cat <<EOF

Log out fully and back in after updating group membership.
EOF
  exit 1
}

resolve_adb_serial() {
  local adb_ip_and_port
  local adb_port

  if [[ -f "${CVD_CONFIG_PATH}" ]]; then
    adb_ip_and_port="$(grep -oE '"adb_ip_and_port"[[:space:]]*:[[:space:]]*"[^"]+"' "${CVD_CONFIG_PATH}" | head -n1 | sed -E 's/.*"([^"]+)"$/\1/' || true)"
    if [[ -n "${adb_ip_and_port}" ]]; then
      printf '%s\n' "${adb_ip_and_port}"
      return 0
    fi

    adb_port="$(grep -oE '"adb_host_port"[[:space:]]*:[[:space:]]*[0-9]+' "${CVD_CONFIG_PATH}" | head -n1 | grep -oE '[0-9]+$' || true)"
    if [[ -n "${adb_port}" ]]; then
      printf '0.0.0.0:%s\n' "${adb_port}"
      return 0
    fi
  fi

  printf '0.0.0.0:6520\n'
}

has_live_cvd_processes() {
  pgrep -f "${CVD_PROCESS_REGEX}" >/dev/null 2>&1
}

stop_dnsmasq() {
  local pid_file
  for pid_file in /var/tmp/cvd/cuttlefish-dnsmasq-*.pid /var/run/cuttlefish-dnsmasq-*.pid; do
    [[ -f "${pid_file}" ]] || continue
    kill "$(cat "${pid_file}")" 2>/dev/null || true
    rm -f "${pid_file}"
    rm -f "${pid_file%.pid}.leases"
  done
  pkill -f 'dnsmasq.*cvd-' 2>/dev/null || true
}

cleanup_user_processes() {
  local -a pids=()
  local pid

  while read -r pid; do
    [[ -n "${pid}" ]] || continue
    [[ "${pid}" == "$$" ]] && continue
    pids+=("${pid}")
  done < <(pgrep -f "${CVD_PROCESS_REGEX}" || true)

  if [[ "${#pids[@]}" -eq 0 ]]; then
    return 0
  fi

  mapfile -t pids < <(printf '%s\n' "${pids[@]}" | sort -u)
  log "stopping leftover Cuttlefish processes: ${pids[*]}"
  kill "${pids[@]}" 2>/dev/null || true
  sleep 1
  kill -9 "${pids[@]}" 2>/dev/null || true
}

within_deadline() {
  local deadline="$1"
  [[ "${deadline}" -eq 0 || ${SECONDS} -lt ${deadline} ]]
}

make_deadline() {
  local timeout_sec="$1"
  if [[ "${timeout_sec}" -gt 0 ]]; then
    printf '%s\n' "$((SECONDS + timeout_sec))"
  else
    printf '0\n'
  fi
}

wait_for_adb_device_while_running() {
  local adb_serial="$1"

  while has_live_cvd_processes; do
    adb connect "${adb_serial}" >/dev/null 2>&1 || true
    if [[ "$(adb -s "${adb_serial}" get-state 2>/dev/null || true)" == "device" ]]; then
      return 0
    fi
    sleep 1.5
  done

  log "guest ADB never became ready before Cuttlefish exited."
  return 1
}

wifi_connected_to_target() {
  local adb_serial="$1"

  adb -s "${adb_serial}" shell cmd wifi status 2>/dev/null |
    grep -Fq "Wifi is connected to \"${CVD_WIFI_AUTO_SSID}\""
}

maybe_configure_virtual_wifi() {
  local adb_serial="$1"
  local wifi_enabled="$2"

  if [[ "${wifi_enabled}" != "true" ]]; then
    log "virtual Wi-Fi disabled for this launch; skipping guest Wi-Fi setup."
    return 0
  fi

  if [[ "${CVD_WIFI_AUTO_CONNECT}" != "true" ]]; then
    log "virtual Wi-Fi auto-connect disabled; skipping guest Wi-Fi setup."
    return 0
  fi

  if ! command -v adb >/dev/null 2>&1; then
    log "adb not found; skipping virtual Wi-Fi setup."
    return 1
  fi

  if ! wait_for_adb_device_while_running "${adb_serial}"; then
    return 1
  fi

  if wifi_connected_to_target "${adb_serial}"; then
    log "virtual Wi-Fi already connected to ${CVD_WIFI_AUTO_SSID}."
    return 0
  fi

  log "enabling Wi-Fi on ${adb_serial}"
  adb -s "${adb_serial}" shell cmd wifi set-wifi-enabled enabled >/dev/null 2>&1 ||
    adb -s "${adb_serial}" shell svc wifi enable >/dev/null 2>&1 || true
  adb -s "${adb_serial}" shell cmd wifi start-scan >/dev/null 2>&1 || true
  sleep 1

  log "connecting Wi-Fi network ${CVD_WIFI_AUTO_SSID}"
  if [[ -n "${CVD_WIFI_AUTO_PASSPHRASE}" ]]; then
    adb -s "${adb_serial}" shell cmd wifi connect-network \
      "${CVD_WIFI_AUTO_SSID}" \
      "${CVD_WIFI_AUTO_SECURITY}" \
      "${CVD_WIFI_AUTO_PASSPHRASE}" >/dev/null 2>&1 || true
  else
    adb -s "${adb_serial}" shell cmd wifi connect-network \
      "${CVD_WIFI_AUTO_SSID}" \
      "${CVD_WIFI_AUTO_SECURITY}" >/dev/null 2>&1 || true
  fi

  while has_live_cvd_processes; do
    if wifi_connected_to_target "${adb_serial}"; then
      log "virtual Wi-Fi connected to ${CVD_WIFI_AUTO_SSID}."
      return 0
    fi
    sleep 1.5
  done

  log "virtual Wi-Fi setup stopped because Cuttlefish exited before connection completed."
  return 1
}

schedule_virtual_wifi_configuration() {
  local adb_serial="$1"
  local wifi_enabled="$2"

  (
    maybe_configure_virtual_wifi "${adb_serial}" "${wifi_enabled}" || true
  ) &

  disown || true
  log "scheduled guest Wi-Fi auto-connect in the background"
}

wait_for_boot() {
  local launcher_log="$1"
  local deadline="$2"
  local min_mtime="${3:-0}"
  local min_offset="${4:-0}"
  local crosvm_command_reported="false"

  while within_deadline "${deadline}"; do
    if [[ -f "${launcher_log}" ]]; then
      local log_mtime
      log_mtime="$(stat -c '%Y' "${launcher_log}" 2>/dev/null || echo 0)"
      if [[ "${crosvm_command_reported}" != "true" ]]; then
        if maybe_respond_crosvm_command "${launcher_log}" "${min_mtime}"; then
          crosvm_command_reported="true"
        fi
      fi
      if [[ "${log_mtime}" -ge "${min_mtime}" ]] &&
         launcher_log_contains_message_since_offset "${launcher_log}" "${CVD_BOOT_MESSAGE}" "${min_offset}"; then
        return 0
      fi
    fi
    if ! has_live_cvd_processes; then
      return 1
    fi
    sleep 0.5
  done

  return 1
}

launcher_log_contains_message_since_offset() {
  local launcher_log="$1"
  local message="$2"
  local min_offset="${3:-0}"
  local file_size
  local effective_offset

  [[ -f "${launcher_log}" ]] || return 1

  file_size="$(stat -c '%s' "${launcher_log}" 2>/dev/null || echo 0)"
  effective_offset="${min_offset}"

  # launcher.log can be rotated/truncated during startup; if the saved offset
  # points past EOF, reset to the current file start so new messages are visible.
  if [[ "${effective_offset}" -gt "${file_size}" ]]; then
    effective_offset=0
  fi

  tail -c "+$((effective_offset + 1))" "${launcher_log}" 2>/dev/null | grep -Fq "${message}"
}

stop_running_scrcpy() {
  local deadline

  if ! pgrep -x scrcpy >/dev/null 2>&1; then
    return 0
  fi

  log "stopping existing scrcpy session"
  pkill -x scrcpy >/dev/null 2>&1 || true

  deadline="$(make_deadline 5)"
  while pgrep -x scrcpy >/dev/null 2>&1; do
    if ! within_deadline "${deadline}"; then
      log "existing scrcpy session did not exit cleanly; forcing termination"
      pkill -9 -x scrcpy >/dev/null 2>&1 || true
      sleep 0.5
      break
    fi
    sleep 0.2
  done
}

start_scrcpy_with_retries() {
  local adb_serial="$1"
  local fullscreen_mode="${2:-false}"
  local attempt=1
  local max_attempts=5
  local -a scrcpy_cmd=(
    "${SCRCPY_BIN}"
    -s "${adb_serial}"
  )
  if [[ -n "${SCRCPY_FLEX_DISPLAY_FLAG}" ]]; then
    scrcpy_cmd+=("${SCRCPY_FLEX_DISPLAY_FLAG}")
  fi
  scrcpy_cmd+=(
    --force-adb-forward
    --window-borderless
    --render-fit=natural
    --video-bit-rate=36M
    --audio-buffer=80
    --audio-codec=raw
    --mouse-bind=+hsn:b+++
  )

  if [[ -d "${SCRCPY_ICON_DIR_DEFAULT}" ]]; then
    scrcpy_cmd=(
      env
      "SCRCPY_ICON_DIR=${SCRCPY_ICON_DIR_DEFAULT}"
      "${scrcpy_cmd[@]}"
    )
  fi

  if [[ -n "${SCRCPY_SERVER_PATH_OVERRIDE}" && -f "${SCRCPY_SERVER_PATH_OVERRIDE}" ]]; then
    scrcpy_cmd=(
      env
      "SCRCPY_SERVER_PATH=${SCRCPY_SERVER_PATH_OVERRIDE}"
      "${scrcpy_cmd[@]}"
    )
  fi

  stop_running_scrcpy

  while [[ "${attempt}" -le "${max_attempts}" ]]; do
    log "starting scrcpy for ${adb_serial} (attempt ${attempt})"
    if [[ "${fullscreen_mode}" == "true" ]]; then
      "${scrcpy_cmd[@]}" --fullscreen >/dev/null 2>&1 &
    else
      "${scrcpy_cmd[@]}" >/dev/null 2>&1 &
    fi
    disown || true

    sleep 1.5
    if pgrep -x scrcpy >/dev/null 2>&1; then
      return 0
    fi

    log "scrcpy exited quickly; retrying."
    attempt=$((attempt + 1))
    if [[ "${attempt}" -le "${max_attempts}" ]]; then
      sleep 1
    fi
  done

  log "unable to keep scrcpy running after ${max_attempts} attempts."
  return 1
}

schedule_scrcpy_when_launcher_ready() {
  local adb_serial="$1"
  local launcher_log="$2"
  local fullscreen_mode="${3:-false}"
  local min_log_offset="${4:-0}"

  (
    while has_live_cvd_processes; do
      if launcher_log_contains_message_since_offset "${launcher_log}" "${CVD_BOOT_MESSAGE}" "${min_log_offset}"; then
        break
      fi
      sleep 0.5
    done

    if ! has_live_cvd_processes; then
      log "deferred scrcpy watcher stopped because Cuttlefish exited before ${CVD_BOOT_MESSAGE}."
      exit 0
    fi
    start_scrcpy_with_retries "${adb_serial}" "${fullscreen_mode}" || true
  ) &

  disown || true
  log "scheduled scrcpy launch when launcher logs ${CVD_BOOT_MESSAGE}"
}

maybe_start_scrcpy() {
  local adb_serial="$1"
  local launcher_log="$2"
  local fullscreen_mode="${3:-false}"
  local min_log_offset="${4:-0}"

  if [[ ! -x "${SCRCPY_BIN}" ]]; then
    log "scrcpy not found at ${SCRCPY_BIN}; skipping client launch."
    return 0
  fi

  if launcher_log_contains_message_since_offset "${launcher_log}" "${CVD_BOOT_MESSAGE}" "${min_log_offset}"; then
    log "launcher already contains ${CVD_BOOT_MESSAGE}; starting scrcpy immediately."
    start_scrcpy_with_retries "${adb_serial}" "${fullscreen_mode}" || true
    return 0
  fi

  log "launcher has not yet logged ${CVD_BOOT_MESSAGE}; deferring scrcpy launch."
  schedule_scrcpy_when_launcher_ready "${adb_serial}" "${launcher_log}" "${fullscreen_mode}" "${min_log_offset}"
  return 0
}

start_cvd() {
  local fullscreen_mode="${1:-false}"
  shift || true
  local -a args=()
  local launcher_log
  local adb_serial
  local boot_deadline
  local wifi_enabled
  local start_epoch
  local launcher_log_offset="0"
  local scrcpy_flex_display

  require_executable "${CVD_BIN}" "cvd launcher"
  check_required_groups
  launcher_log="${CVD_LAUNCHER_LOG}"
  adb_serial="$(resolve_adb_serial)"
  start_epoch="$(date +%s)"
  scrcpy_flex_display="$(scrcpy_flex_display_value "$@")"
  configure_scrcpy_flex_display_flag "${scrcpy_flex_display}"

  if has_live_cvd_processes; then
    log "Cuttlefish is already running under ${CVD_HOME_DIR}"
    respond_console "Instance already running, restarting console viewer."
    respond "Android virtual device running"
    maybe_start_scrcpy "${adb_serial}" "${launcher_log}" "${fullscreen_mode}" "0" || true
    return 0
  fi

  if [[ -f "${launcher_log}" ]]; then
    launcher_log_offset="$(stat -c '%s' "${launcher_log}" 2>/dev/null || echo 0)"
  fi


  # Apply default arguments from configuration maps.
  local config_map
  for config_map in \
    CVD_COMPUTE_DEFAULTS \
    CVD_GPU_DEFAULTS \
    CVD_NETWORK_DEFAULTS \
    CVD_DISPLAY_DEFAULTS \
    CVD_REPORT_DEFAULTS \
    CVD_OVERLAY_DEFAULTS; do
    apply_default_args "${config_map}" args "$@"
  done

  append_cvd_args args "$@"

  local tz
  tz="$(readlink /etc/localtime 2>/dev/null | sed 's|.*/zoneinfo/||')"
  if [[ -n "${tz}" ]]; then
    args+=("--extra_bootconfig_args=androidboot.timezone=\"${tz}\"")
    log "timezone: ${tz}"
  fi

  wifi_enabled="$(flag_value "enable_wifi" "${CVD_ENABLE_WIFI}" "${args[@]}")"

  log "starting Cuttlefish with $(basename "${CVD_BIN}")"
  printf '[%s] starting Cuttlefish with %s\n' "${SCRIPT_NAME}" "$(basename "${CVD_BIN}")" >&3
  log "HOME=${CVD_HOME_DIR}"
  log "ANDROID_HOST_OUT=${CVD_HOST_OUT}"
  log "ANDROID_PRODUCT_OUT=${CVD_PRODUCT_OUT}"
  log "gpu_mode=${CVD_GPU_MODE}"
  log "launcher_log=${launcher_log}"
  emit_launch_command "${args[@]}"

  (
    cd "${CVD_PRODUCT_OUT}"
    run_with_cvd_env "${CVD_BIN}" "${args[@]}"
  ) &

  log "launcher pid: $!"

  boot_deadline="$(make_deadline "${CVD_BOOT_TIMEOUT_SEC}")"
  if ! wait_for_boot "${launcher_log}" "${boot_deadline}" "${start_epoch}" "${launcher_log_offset}"; then
    if [[ -f "${launcher_log}" ]]; then
      tail -n 80 "${launcher_log}" >&2 || true
    fi
    die "Cuttlefish did not reach boot completion"
  fi

  log "boot completed after seeing: ${CVD_BOOT_MESSAGE}"
  respond "Android virtual device running"
  maybe_start_scrcpy "${adb_serial}" "${launcher_log}" "${fullscreen_mode}" "${launcher_log_offset}" || true
  schedule_virtual_wifi_configuration "${adb_serial}" "${wifi_enabled}"
}

stop_cvd_internal() {
  local clear_instance_dirs="${1:-false}"
  shift || true
  local stop_ok="false"
  local -a stop_args=()

  if [[ "${clear_instance_dirs}" == "true" ]]; then
    stop_args+=("--clear_instance_dirs")
  fi
  stop_args+=("$@")

  require_executable "${CVD_STOP_BIN}" "cvd stop helper"

  if [[ "${clear_instance_dirs}" == "true" ]]; then
    log "stopping Cuttlefish and clearing instance dirs with $(basename "${CVD_STOP_BIN}")"
  else
    log "stopping Cuttlefish with $(basename "${CVD_STOP_BIN}")"
  fi

  if [[ -f "${CVD_CONFIG_PATH}" ]]; then
    if run_with_cvd_env --config "${CVD_CONFIG_PATH}" "${CVD_STOP_BIN}" "${stop_args[@]}"; then
      stop_ok="true"
    else
      log "primary stop helper returned non-zero"
    fi
  else
    if run_with_cvd_env "${CVD_STOP_BIN}" "${stop_args[@]}"; then
      stop_ok="true"
    else
      log "primary stop helper returned non-zero"
    fi
  fi

  if [[ "${stop_ok}" != "true" ]]; then
    log "retrying stop via $(basename "${CVD_CLI_BIN}") stop"
    run_with_cvd_env "${CVD_CLI_BIN}" stop "${stop_args[@]}" && stop_ok="true" || true
  fi

  if [[ "${clear_instance_dirs}" == "true" ]]; then
    run_with_cvd_env "${CVD_CLI_BIN}" clear >/dev/null 2>&1 || true
  fi

  stop_dnsmasq
  cleanup_user_processes

  if has_live_cvd_processes; then
    die "Cuttlefish processes are still running after stop attempt"
  fi

  if [[ "${stop_ok}" != "true" ]]; then
    log "stop helper reported no active device; no live Cuttlefish processes remain"
  fi

  respond "Android virtual device stopped."
}
main() {
  local command="${1:-help}"
  local fullscreen_mode
  local -a start_args

  case "${command}" in
    start)
      CONSOLE_FAILURE_MESSAGE="Startup Failed."
      redirect_start_logs
      shift
      start_args=()
      parse_start_options fullscreen_mode start_args "$@"
      run_timed_operation "started" start_cvd "${fullscreen_mode}" "${start_args[@]}"
      ;;
    stop)
      shift
      stop_cvd_internal false "$@"
      ;;
    reset)
      shift
      stop_cvd_internal true "$@"
      ;;
    restart)
      shift
      start_args=()
      parse_start_options fullscreen_mode start_args "$@"
      stop_cvd_internal false
      sleep 0.5
      if [[ "${fullscreen_mode}" == "true" ]]; then
        exec "$0" start --fullscreen "${start_args[@]}"
      fi
      exec "$0" start "${start_args[@]}"
      ;;
    status)
      if has_live_cvd_processes; then
        respond "Android virtual device running."
      else
        respond "Android virtual device not running."
      fi
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
