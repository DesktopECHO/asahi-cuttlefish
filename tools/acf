#!/usr/bin/env bash

set -euo pipefail

exec 3>&1

LOG_FILE="/tmp/acf.log"
START_LOG_FILE="/tmp/acfstart.log"
STOP_LOG_FILE="/tmp/acfstop.log"
mkdir -p "$(dirname "${LOG_FILE}")"
: > "${LOG_FILE}"
exec >>"${LOG_FILE}" 2>&1

# ============================================================================
# Environment Paths
# ============================================================================
CVD_HOST_OUT="${ANDROID_HOST_OUT:-/usr/lib/cuttlefish-common}"
CVD_PRODUCT_OUT="${ANDROID_PRODUCT_OUT:-/usr/share/cuttlefish-common/aosp}"
: "${CVD_HOME_DIR:=${CVD_PRODUCT_OUT}}"
CVD_BIN="${CVD_HOST_OUT}/bin/cvd_internal_start"
CVD_CLI_BIN="${CVD_HOST_OUT}/bin/cvd"

# ============================================================================
# Compute Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
declare -A CVD_COMPUTE_DEFAULTS=(
  [cpus]="4"
  [memory_mb]="4096"
)

# ============================================================================
# GPU Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
declare -A CVD_GPU_DEFAULTS=(
  [gpu_mode]="gfxstream"
  [gpu_vhost_user_mode]="off"
  [enable_gpu_udmabuf]="true"
  [use_cvdalloc]="true"
)

# ============================================================================
# Network Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
declare -A CVD_NETWORK_DEFAULTS=(
  [vhost_net]="true"
  [vhost_user_vsock]="false"
  [enable_wifi]="true"
  [enable_modem_simulator]="false"
  [enable_host_uwb]="false"
  [netsim_uwb]="false"
)

# ============================================================================
# Display Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
declare -A CVD_DISPLAY_DEFAULTS=(
  [x_res]="1920"
  [y_res]="1200"
  [dpi]="192"
)

# ============================================================================
# Reporting Configuration Defaults (passed to cvd_internal_start)
# ============================================================================
declare -A CVD_REPORT_DEFAULTS=(
  [report_anonymous_usage_stats]="n"
)

# ============================================================================
# Wi-Fi Auto-Connect Configuration Defaults (internal use only)
# ============================================================================
declare -A CVD_WIFI_DEFAULTS=(
  [wifi_auto_connect]="true"
  [wifi_auto_ssid]="VirtWifi"
  [wifi_auto_security]="open"
  [wifi_auto_passphrase]=""
)

# ============================================================================

# Boot & Logging Configuration Defaults (internal use only)
# ============================================================================
declare -A CVD_BOOT_DEFAULTS=(
  [boot_message]="Virtual device booted successfully"
  [scrcpy_ready_message]="VIRTUAL_DEVICE_BOOT_COMPLETED"
  [boot_timeout_sec]="60"
  [start_scrcpy_timeout_sec]="45"
)

# Overlay Option Default
# ============================================================================
declare -A CVD_OVERLAY_DEFAULTS=(
  [use_overlay]="false"
)

# Convenience variables (for backward compatibility)
CVD_CPUS="${CVD_COMPUTE_DEFAULTS[cpus]}"
CVD_MEMORY_MB="${CVD_COMPUTE_DEFAULTS[memory_mb]}"
CVD_GPU_MODE="${CVD_GPU_DEFAULTS[gpu_mode]}"
CVD_GPU_VHOST_USER_MODE="${CVD_GPU_DEFAULTS[gpu_vhost_user_mode]}"
CVD_ENABLE_GPU_UDMABUF="${CVD_GPU_DEFAULTS[enable_gpu_udmabuf]}"
CVD_USE_CVDALLOC="${CVD_GPU_DEFAULTS[use_cvdalloc]}"
CVD_VHOST_NET="${CVD_NETWORK_DEFAULTS[vhost_net]}"
CVD_VHOST_USER_VSOCK="${CVD_NETWORK_DEFAULTS[vhost_user_vsock]}"
CVD_ENABLE_WIFI="${CVD_NETWORK_DEFAULTS[enable_wifi]}"
CVD_ENABLE_MODEM_SIMULATOR="${CVD_NETWORK_DEFAULTS[enable_modem_simulator]}"
CVD_ENABLE_HOST_UWB="${CVD_NETWORK_DEFAULTS[enable_host_uwb]}"
CVD_NETSIM_UWB="${CVD_NETWORK_DEFAULTS[netsim_uwb]}"
CVD_X_RES="${CVD_DISPLAY_DEFAULTS[x_res]}"
CVD_Y_RES="${CVD_DISPLAY_DEFAULTS[y_res]}"
CVD_DPI="${CVD_DISPLAY_DEFAULTS[dpi]}"
CVD_REPORT_USAGE_STATS="${CVD_REPORT_DEFAULTS[report_anonymous_usage_stats]}"
CVD_WIFI_AUTO_CONNECT="${CVD_WIFI_DEFAULTS[wifi_auto_connect]}"
CVD_WIFI_AUTO_SSID="${CVD_WIFI_DEFAULTS[wifi_auto_ssid]}"
CVD_WIFI_AUTO_SECURITY="${CVD_WIFI_DEFAULTS[wifi_auto_security]}"
CVD_WIFI_AUTO_PASSPHRASE="${CVD_WIFI_DEFAULTS[wifi_auto_passphrase]}"
CVD_BOOT_MESSAGE="${CVD_BOOT_DEFAULTS[boot_message]}"
CVD_SCRCPY_READY_MESSAGE="${CVD_BOOT_DEFAULTS[scrcpy_ready_message]}"
CVD_BOOT_TIMEOUT_SEC="${CVD_BOOT_DEFAULTS[boot_timeout_sec]}"
CVD_START_SCRCPY_TIMEOUT_SEC="${CVD_BOOT_DEFAULTS[start_scrcpy_timeout_sec]}"

CVD_PROCESS_NAMES=(
  "cvd_internal_start"
  "launch_cvd"
  "run_cvd"
  "crosvm"
  "process_restarter"
  "socket_vsock_proxy"
  "wmediumd"
  "webRTC"
)

CVD_PROCESS_REGEX='(^|/)(cvd_internal_start|launch_cvd|run_cvd|crosvm|process_restarter|socket_vsock_proxy|wmediumd|webRTC)([[:space:]]|$)'

SCRIPT_NAME="$(basename "$0")"

log() {
  printf '[%s] %s\n' "${SCRIPT_NAME}" "$*" >&2
}

die() {
  log "error: $*"
  exit 1
}

respond() {
  printf '%s\n' "$*"
}

console_notify() {
  local action="$1"
  local elapsed_sec="$2"
  printf 'Android %s in %ss.\n' "${action}" "${elapsed_sec}" >&3
}

run_timed_operation() {
  local action="$1"
  shift

  local start_epoch
  local elapsed_sec

  start_epoch="$(date +%s)"
  "$@"
  elapsed_sec="$(( $(date +%s) - start_epoch ))"

  console_notify "${action}" "${elapsed_sec}"
}

redirect_start_logs() {
  mkdir -p "$(dirname "${START_LOG_FILE}")"
  : > "${START_LOG_FILE}"
  exec >"${START_LOG_FILE}" 2>&1
}

redirect_stop_logs() {
  mkdir -p "$(dirname "${STOP_LOG_FILE}")"
  : > "${STOP_LOG_FILE}"
  exec >"${STOP_LOG_FILE}" 2>&1
}

usage() {
  local output_fd="${1:-1}"
  cat >&"${output_fd}" <<EOF
Usage:

  ${SCRIPT_NAME} start [cvd_internal_start args...]       · Start windowed
  ${SCRIPT_NAME} startfs [cvd_internal_start args...]     · Start fullscreen
  ${SCRIPT_NAME} stop [stop_cvd args...]
  ${SCRIPT_NAME} reset [stop_cvd args...]                 · Stop + clear state
  ${SCRIPT_NAME} restart [cvd_internal_start args...]
  ${SCRIPT_NAME} status
  ${SCRIPT_NAME} help

Notes:

  - Edit the variables at the top of this script to change defaults.
  - Extra arguments after 'start' are passed directly to cvd_internal_start.
  - Extra arguments after 'startfs' are passed directly to cvd_internal_start.
  - Extra arguments after 'stop' are passed directly to stop_cvd.
  - 'stop' preserves instance data (apps/userdata).
  - Extra arguments after 'reset' are passed directly to stop_cvd.
  - 'reset' clears instance directories and returns to factory state.
  - Extra arguments after 'restart' are passed directly to cvd_internal_start.
  - Common radio/network overrides:
      --enable_wifi=<true|false>
      --enable_modem_simulator=<true|false>
      --enable_host_uwb=<true|false>
      --netsim_uwb=<true|false>
  - Current defaults use Wi-Fi/OpenWRT and disable the modem simulator and
    UWB:
      --enable_wifi=true
      --enable_modem_simulator=false
      --enable_host_uwb=false
      --netsim_uwb=false
  - Virtual Wi-Fi auto-connect defaults:
      ssid=${CVD_WIFI_AUTO_SSID}
      security=${CVD_WIFI_AUTO_SECURITY}
      auto_connect=${CVD_WIFI_AUTO_CONNECT}

EOF
}

shell_join() {
  local joined
  printf -v joined '%q ' "$@"
  printf '%s' "${joined% }"
}

latest_launcher_log_message() {
  local launcher_log="$1"
  local min_mtime="$2"
  local pattern="$3"
  local log_mtime

  [[ -f "${launcher_log}" ]] || return 1

  log_mtime="$(stat -c '%Y' "${launcher_log}" 2>/dev/null || echo 0)"
  [[ "${log_mtime}" -ge "${min_mtime}" ]] || return 1

  grep -F "${pattern}" "${launcher_log}" | tail -n 1 || true
}

maybe_respond_crosvm_command() {
  local launcher_log="$1"
  local min_mtime="$2"
  local line
  local command

  line="$(latest_launcher_log_message "${launcher_log}" "${min_mtime}" "crosvm launch command:")"
  [[ -n "${line}" ]] || return 1

  command="${line#*"crosvm launch command: "}"
  respond "[${SCRIPT_NAME}] crosvm launch command: ${command}"
  return 0
}

emit_launch_command() {
  local launch_command

  launch_command="$(
    shell_join \
      env \
      "HOME=${CVD_HOME_DIR}" \
      "ANDROID_HOST_OUT=${CVD_HOST_OUT}" \
      "ANDROID_SOONG_HOST_OUT=${CVD_HOST_OUT}" \
      "ANDROID_PRODUCT_OUT=${CVD_PRODUCT_OUT}" \
      "${CVD_BIN}" \
      "$@"
  )"

  log "launch command: cd $(printf '%q' "${CVD_PRODUCT_OUT}") && ${launch_command}"
}

user_supplied_flag() {
  local flag="$1"
  shift
  local arg
  for arg in "$@"; do
    case "${arg}" in
      "--${flag}"|"--${flag}="*|"-${flag}"|"-${flag}="*)
        return 0
        ;;
    esac
  done
  return 1
}

flag_value() {
  local flag="$1"
  local default_value="$2"
  shift 2
  local value="${default_value}"
  local arg

  for arg in "$@"; do
    case "${arg}" in
      "--${flag}="*|"-${flag}="*)
        value="${arg#*=}"
        ;;
      "--${flag}"|"-${flag}")
        value="true"
        ;;
    esac
  done

  printf '%s\n' "${value}"
}

require_executable() {
  local path="$1"
  local label="$2"
  [[ -x "${path}" ]] || die "${label} not found or not executable: ${path}"
}

apply_default_args() {
  local -n config_map="$1"
  local -n args_array="$2"
  shift 2
  local key value

  for key in "${!config_map[@]}"; do
    if ! user_supplied_flag "${key}" "$@"; then
      value="${config_map[${key}]}"
      # Handle special case for report_anonymous_usage_stats which uses single dash
      if [[ "${key}" == "report_anonymous_usage_stats" ]]; then
        args_array+=("-${key}=${value}")
      else
        args_array+=("--${key}=${value}")
      fi
    fi
  done
}

run_with_cvd_env() {
  env \
    HOME="${CVD_HOME_DIR}" \
    ANDROID_HOST_OUT="${CVD_HOST_OUT}" \
    ANDROID_SOONG_HOST_OUT="${CVD_HOST_OUT}" \
    ANDROID_PRODUCT_OUT="${CVD_PRODUCT_OUT}" \
    "$@"
}

run_with_cvd_env_and_config() {
  local config_path="$1"
  shift

  env \
    HOME="${CVD_HOME_DIR}" \
    ANDROID_HOST_OUT="${CVD_HOST_OUT}" \
    ANDROID_SOONG_HOST_OUT="${CVD_HOST_OUT}" \
    ANDROID_PRODUCT_OUT="${CVD_PRODUCT_OUT}" \
    CUTTLEFISH_CONFIG_FILE="${config_path}" \
    "$@"
}

has_session_group() {
  id -nG | tr ' ' '\n' | grep -Fxq "$1"
}

has_configured_group() {
  id -nG "${USER}" | tr ' ' '\n' | grep -Fxq "$1"
}

check_required_groups() {
  local -a required_groups=(kvm video render cvdnetwork)
  local -a missing_groups=()
  local -a inactive_groups=()
  local -a add_groups=()
  local group

  for group in "${required_groups[@]}"; do
    if getent group "${group}" >/dev/null 2>&1 && ! has_session_group "${group}"; then
      missing_groups+=("${group}")
      if has_configured_group "${group}"; then
        inactive_groups+=("${group}")
      else
        add_groups+=("${group}")
      fi
    fi
  done

  if [[ "${#missing_groups[@]}" -eq 0 ]]; then
    return 0
  fi

  cat <<EOF
[${SCRIPT_NAME}] error: current shell is missing required groups.

Active groups:
  $(id -nG)

Missing groups:
  ${missing_groups[*]}

EOF

  if [[ "${#add_groups[@]}" -gt 0 ]]; then
    cat <<EOF
To add the missing account membership:
  sudo usermod -aG ${add_groups[*]} ${USER}

EOF
  fi

  if [[ "${#inactive_groups[@]}" -gt 0 ]]; then
    cat <<EOF
Configured on the account but not active in this login session:
  ${inactive_groups[*]}

EOF
  fi

  cat <<EOF

Log out fully and back in after updating group membership.
EOF
  exit 1
}

resolve_launcher_log() {
  local -a candidates=(
    "${CVD_HOME_DIR}/cuttlefish/instances/cvd-1/logs/launcher.log"
    "${CVD_HOME_DIR}/cvd-1/logs/launcher.log"
  )
  local candidate

  for candidate in "${candidates[@]}"; do
    if [[ -e "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  printf '%s\n' "${candidates[0]}"
}

resolve_config_json() {
  local -a candidates=(
    "${CVD_HOME_DIR}/cuttlefish/instances/cvd-1/cuttlefish_config.json"
    "${CVD_HOME_DIR}/cvd-1/cuttlefish_config.json"
  )
  local candidate

  for candidate in "${candidates[@]}"; do
    if [[ -f "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  printf '%s\n' "${candidates[0]}"
}

resolve_stop_bin() {
  local -a candidates=(
    "${CVD_HOST_OUT}/bin/cvd_internal_stop"
    "${CVD_HOST_OUT}/bin/stop_cvd"
  )
  local candidate

  for candidate in "${candidates[@]}"; do
    if [[ -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  printf '%s\n' "${candidates[0]}"
}

resolve_adb_serial() {
  local config_path
  local adb_ip_and_port
  local adb_port

  config_path="$(resolve_config_json)"
  if [[ -f "${config_path}" ]]; then
    adb_ip_and_port="$(grep -oE '"adb_ip_and_port"[[:space:]]*:[[:space:]]*"[^"]+"' "${config_path}" | head -n1 | sed -E 's/.*"([^"]+)"$/\1/' || true)"
    if [[ -n "${adb_ip_and_port}" ]]; then
      printf '%s\n' "${adb_ip_and_port}"
      return 0
    fi

    adb_port="$(grep -oE '"adb_host_port"[[:space:]]*:[[:space:]]*[0-9]+' "${config_path}" | head -n1 | grep -oE '[0-9]+$' || true)"
    if [[ -n "${adb_port}" ]]; then
      printf '0.0.0.0:%s\n' "${adb_port}"
      return 0
    fi
  fi

  printf '0.0.0.0:6520\n'
}

has_live_cvd_processes() {
  pgrep -f "${CVD_PROCESS_REGEX}" >/dev/null 2>&1
}

cleanup_user_processes() {
  local -a pids=()
  local pid

  while read -r pid; do
    [[ -n "${pid}" ]] || continue
    [[ "${pid}" == "$$" ]] && continue
    pids+=("${pid}")
  done < <(pgrep -f "${CVD_PROCESS_REGEX}" || true)

  if [[ "${#pids[@]}" -eq 0 ]]; then
    return 0
  fi

  mapfile -t pids < <(printf '%s\n' "${pids[@]}" | sort -u)
  log "stopping leftover Cuttlefish processes: ${pids[*]}"
  kill "${pids[@]}" 2>/dev/null || true
  sleep 1
  kill -9 "${pids[@]}" 2>/dev/null || true
}

within_deadline() {
  local deadline="$1"
  [[ "${deadline}" -eq 0 || ${SECONDS} -lt ${deadline} ]]
}

make_deadline() {
  local timeout_sec="$1"
  if [[ "${timeout_sec}" -gt 0 ]]; then
    printf '%s\n' "$((SECONDS + timeout_sec))"
  else
    printf '0\n'
  fi
}

wait_for_adb_device_forever() {
  local adb_serial="$1"

  while true; do
    adb connect "${adb_serial}" >/dev/null 2>&1 || true
    if [[ "$(adb -s "${adb_serial}" get-state 2>/dev/null || true)" == "device" ]]; then
      return 0
    fi
    sleep 1
  done
}

wifi_connected_to_target() {
  local adb_serial="$1"

  adb -s "${adb_serial}" shell cmd wifi status 2>/dev/null |
    grep -Fq "Wifi is connected to \"${CVD_WIFI_AUTO_SSID}\""
}

maybe_configure_virtual_wifi() {
  local adb_serial="$1"
  local wifi_enabled="$2"

  if [[ "${wifi_enabled}" != "true" ]]; then
    log "virtual Wi-Fi disabled for this launch; skipping guest Wi-Fi setup."
    return 0
  fi

  if [[ "${CVD_WIFI_AUTO_CONNECT}" != "true" ]]; then
    log "virtual Wi-Fi auto-connect disabled; skipping guest Wi-Fi setup."
    return 0
  fi

  if ! command -v adb >/dev/null 2>&1; then
    log "adb not found; skipping virtual Wi-Fi setup."
    return 1
  fi

  wait_for_adb_device_forever "${adb_serial}"

  if wifi_connected_to_target "${adb_serial}"; then
    log "virtual Wi-Fi already connected to ${CVD_WIFI_AUTO_SSID}."
    return 0
  fi

  log "enabling Wi-Fi on ${adb_serial}"
  adb -s "${adb_serial}" shell cmd wifi set-wifi-enabled enabled >/dev/null 2>&1 ||
    adb -s "${adb_serial}" shell svc wifi enable >/dev/null 2>&1 || true
  adb -s "${adb_serial}" shell cmd wifi start-scan >/dev/null 2>&1 || true
  sleep 1

  log "connecting Wi-Fi network ${CVD_WIFI_AUTO_SSID}"
  if [[ -n "${CVD_WIFI_AUTO_PASSPHRASE}" ]]; then
    adb -s "${adb_serial}" shell cmd wifi connect-network \
      "${CVD_WIFI_AUTO_SSID}" \
      "${CVD_WIFI_AUTO_SECURITY}" \
      "${CVD_WIFI_AUTO_PASSPHRASE}" >/dev/null 2>&1 || true
  else
    adb -s "${adb_serial}" shell cmd wifi connect-network \
      "${CVD_WIFI_AUTO_SSID}" \
      "${CVD_WIFI_AUTO_SECURITY}" >/dev/null 2>&1 || true
  fi

  while true; do
    if wifi_connected_to_target "${adb_serial}"; then
      log "virtual Wi-Fi connected to ${CVD_WIFI_AUTO_SSID}."
      return 0
    fi
    sleep 1
  done
}

wait_for_boot() {
  local launcher_log="$1"
  local deadline="$2"
  local min_mtime="${3:-0}"
  local crosvm_command_reported="false"

  while within_deadline "${deadline}"; do
    if [[ -f "${launcher_log}" ]]; then
      local log_mtime
      log_mtime="$(stat -c '%Y' "${launcher_log}" 2>/dev/null || echo 0)"
      if [[ "${crosvm_command_reported}" != "true" ]]; then
        if maybe_respond_crosvm_command "${launcher_log}" "${min_mtime}"; then
          crosvm_command_reported="true"
        fi
      fi
      if [[ "${log_mtime}" -ge "${min_mtime}" ]] && grep -Fq "${CVD_BOOT_MESSAGE}" "${launcher_log}"; then
        return 0
      fi
    fi
    if ! has_live_cvd_processes; then
      return 1
    fi
    sleep 0.5
  done

  return 1
}

launcher_log_contains_message_since_offset() {
  local launcher_log="$1"
  local message="$2"
  local min_offset="${3:-0}"
  local file_size
  local effective_offset

  [[ -f "${launcher_log}" ]] || return 1

  file_size="$(stat -c '%s' "${launcher_log}" 2>/dev/null || echo 0)"
  effective_offset="${min_offset}"

  # launcher.log can be rotated/truncated during startup; if the saved offset
  # points past EOF, reset to the current file start so new messages are visible.
  if [[ "${effective_offset}" -gt "${file_size}" ]]; then
    effective_offset=0
  fi

  tail -c "+$((effective_offset + 1))" "${launcher_log}" 2>/dev/null | grep -Fq "${message}"
}

wait_for_launcher_message() {
  local launcher_log="$1"
  local deadline="$2"
  local message="$3"
  local min_offset="${4:-0}"

  while within_deadline "${deadline}"; do
    if launcher_log_contains_message_since_offset "${launcher_log}" "${message}" "${min_offset}"; then
      return 0
    fi
    if ! has_live_cvd_processes; then
      return 1
    fi
    sleep 0.5
  done

  return 1
}

start_scrcpy_with_retries() {
  local adb_serial="$1"
  local fullscreen_mode="${2:-false}"
  local retry_deadline="$3"
  local attempt=1

  while within_deadline "${retry_deadline}"; do
    if pgrep -x scrcpy >/dev/null 2>&1; then
      return 0
    fi

    log "starting scrcpy for ${adb_serial} (attempt ${attempt})"
    if [[ "${fullscreen_mode}" == "true" ]]; then
      scrcpy -s "${adb_serial}" --force-adb-forward --fullscreen >/dev/null 2>&1 &
    else
      scrcpy -s "${adb_serial}" --force-adb-forward >/dev/null 2>&1 &
    fi
    disown || true

    sleep 1
    if pgrep -x scrcpy >/dev/null 2>&1; then
      return 0
    fi

    log "scrcpy exited quickly; retrying."
    attempt=$((attempt + 1))
    sleep 0.5
  done

  log "unable to keep scrcpy running before timeout."
  return 1
}

schedule_scrcpy_when_launcher_ready() {
  local adb_serial="$1"
  local launcher_log="$2"
  local fullscreen_mode="${3:-false}"
  local min_log_offset="${4:-0}"
  local watch_deadline
  local retry_deadline

  watch_deadline="$(make_deadline "${CVD_START_SCRCPY_TIMEOUT_SEC}")"

  (
    if ! wait_for_launcher_message "${launcher_log}" "${watch_deadline}" "${CVD_SCRCPY_READY_MESSAGE}" "${min_log_offset}"; then
      log "deferred scrcpy watcher timed out after ${CVD_START_SCRCPY_TIMEOUT_SEC}s waiting for ${CVD_SCRCPY_READY_MESSAGE}."
      exit 0
    fi
    if pgrep -x scrcpy >/dev/null 2>&1; then
      exit 0
    fi
    retry_deadline="$(make_deadline "${CVD_START_SCRCPY_TIMEOUT_SEC}")"
    start_scrcpy_with_retries "${adb_serial}" "${fullscreen_mode}" "${retry_deadline}" || true
  ) &

  disown || true
  log "scheduled scrcpy launch when launcher logs ${CVD_SCRCPY_READY_MESSAGE}"
}

maybe_start_scrcpy() {
  local adb_serial="$1"
  local launcher_log="$2"
  local deadline="$3"
  local fullscreen_mode="${4:-false}"
  local min_log_offset="${5:-0}"
  local retry_deadline

  if ! command -v scrcpy >/dev/null 2>&1; then
    log "scrcpy not found; skipping client launch."
    return 0
  fi

  if pgrep -x scrcpy >/dev/null 2>&1; then
    log "scrcpy is already running; skipping second launch."
    return 0
  fi

  if launcher_log_contains_message_since_offset "${launcher_log}" "${CVD_SCRCPY_READY_MESSAGE}" "${min_log_offset}"; then
    log "launcher already contains ${CVD_SCRCPY_READY_MESSAGE}; starting scrcpy immediately."
    retry_deadline="$(make_deadline "${CVD_START_SCRCPY_TIMEOUT_SEC}")"
    start_scrcpy_with_retries "${adb_serial}" "${fullscreen_mode}" "${retry_deadline}" || true
    return 0
  fi

  if ! wait_for_launcher_message "${launcher_log}" "${deadline}" "${CVD_SCRCPY_READY_MESSAGE}" "${min_log_offset}"; then
    log "launcher did not log ${CVD_SCRCPY_READY_MESSAGE} before timeout; deferring scrcpy launch."
    schedule_scrcpy_when_launcher_ready "${adb_serial}" "${launcher_log}" "${fullscreen_mode}" "${min_log_offset}"
    return 0
  fi

  start_scrcpy_with_retries "${adb_serial}" "${fullscreen_mode}" "${deadline}" || true
  return 0
}

report_scrcpy_timing() {
  local invocation_epoch="$1"
  local now_epoch elapsed

  now_epoch="$(date +%s)"
  elapsed="$((now_epoch - invocation_epoch))"

  if pgrep -x scrcpy >/dev/null 2>&1; then
    respond "scrcpy running after ${elapsed}s"
  else
    respond "scrcpy not running after ${elapsed}s"
  fi
}

start_cvd() {
  local fullscreen_mode="${1:-false}"
  shift || true
  local -a args=()
  local launcher_log
  local adb_serial
  local boot_deadline
  local wifi_enabled
  local scrcpy_deadline
  local start_epoch
  local invocation_epoch
  local launcher_log_offset="0"

  require_executable "${CVD_BIN}" "cvd launcher"
  check_required_groups
  launcher_log="$(resolve_launcher_log)"
  adb_serial="$(resolve_adb_serial)"
  start_epoch="$(date +%s)"
  invocation_epoch="${start_epoch}"

  scrcpy_deadline="$(make_deadline "${CVD_START_SCRCPY_TIMEOUT_SEC}")"

  if has_live_cvd_processes; then
    log "Cuttlefish is already running under ${CVD_HOME_DIR}"
    respond "Android virtual device running"
    maybe_start_scrcpy "${adb_serial}" "${launcher_log}" "${scrcpy_deadline}" "${fullscreen_mode}" "0" || true
    report_scrcpy_timing "${invocation_epoch}"
    return 0
  fi

  if [[ -f "${launcher_log}" ]]; then
    launcher_log_offset="$(stat -c '%s' "${launcher_log}" 2>/dev/null || echo 0)"
  fi


  # Apply default arguments from configuration maps
  # Only add parameters meant to be passed to cvd_internal_start
  apply_default_args CVD_COMPUTE_DEFAULTS args "$@"
  apply_default_args CVD_GPU_DEFAULTS args "$@"
  apply_default_args CVD_NETWORK_DEFAULTS args "$@"
  apply_default_args CVD_DISPLAY_DEFAULTS args "$@"
  apply_default_args CVD_REPORT_DEFAULTS args "$@"
  apply_default_args CVD_OVERLAY_DEFAULTS args "$@"

  args+=("$@")
  wifi_enabled="$(flag_value "enable_wifi" "${CVD_ENABLE_WIFI}" "${args[@]}")"

  log "starting Cuttlefish"
  log "HOME=${CVD_HOME_DIR}"
  log "ANDROID_HOST_OUT=${CVD_HOST_OUT}"
  log "ANDROID_PRODUCT_OUT=${CVD_PRODUCT_OUT}"
  log "gpu_mode=${CVD_GPU_MODE}"
  log "launcher_log=${launcher_log}"
  emit_launch_command "${args[@]}"

  (
    cd "${CVD_PRODUCT_OUT}"
    run_with_cvd_env "${CVD_BIN}" "${args[@]}"
  ) &

  log "launcher pid: $!"

  boot_deadline="$(make_deadline "${CVD_BOOT_TIMEOUT_SEC}")"
  if ! wait_for_boot "${launcher_log}" "${boot_deadline}" "${start_epoch}"; then
    if [[ -f "${launcher_log}" ]]; then
      tail -n 80 "${launcher_log}" >&2 || true
    fi
    die "Cuttlefish did not reach boot completion"
  fi

  log "boot completed after seeing: ${CVD_BOOT_MESSAGE}"
  respond "Android virtual device running"
  scrcpy_deadline="$(make_deadline "${CVD_START_SCRCPY_TIMEOUT_SEC}")"
  maybe_start_scrcpy "${adb_serial}" "${launcher_log}" "${scrcpy_deadline}" "${fullscreen_mode}" "${launcher_log_offset}" || true
  report_scrcpy_timing "${invocation_epoch}"
  maybe_configure_virtual_wifi "${adb_serial}" "${wifi_enabled}" || true
}

stop_cvd_internal() {
  local clear_instance_dirs="${1:-false}"
  shift || true
  local stop_bin
  local config_path
  local stop_ok="false"
  local -a stop_args=()

  if [[ "${clear_instance_dirs}" == "true" ]]; then
    stop_args+=("--clear_instance_dirs")
  fi
  stop_args+=("$@")

  stop_bin="$(resolve_stop_bin)"
  config_path="$(resolve_config_json)"

  require_executable "${stop_bin}" "cvd stop helper"

  if [[ "${clear_instance_dirs}" == "true" ]]; then
    log "stopping Cuttlefish and clearing instance dirs with $(basename "${stop_bin}")"
  else
    log "stopping Cuttlefish with $(basename "${stop_bin}")"
  fi

  if [[ -f "${config_path}" ]]; then
    if run_with_cvd_env_and_config "${config_path}" "${stop_bin}" "${stop_args[@]}"; then
      stop_ok="true"
    else
      log "primary stop helper returned non-zero"
    fi
  else
    if run_with_cvd_env "${stop_bin}" "${stop_args[@]}"; then
      stop_ok="true"
    else
      log "primary stop helper returned non-zero"
    fi
  fi

  if [[ "${stop_ok}" != "true" ]]; then
    log "retrying stop via $(basename "${CVD_CLI_BIN}") stop"
    run_with_cvd_env "${CVD_CLI_BIN}" stop "${stop_args[@]}" && stop_ok="true" || true
  fi

  if [[ "${clear_instance_dirs}" == "true" ]]; then
    run_with_cvd_env "${CVD_CLI_BIN}" clear >/dev/null 2>&1 || true
  fi

  cleanup_user_processes

  if has_live_cvd_processes; then
    die "Cuttlefish processes are still running after stop attempt"
  fi

  if [[ "${stop_ok}" != "true" ]]; then
    log "stop helper reported no active device; no live Cuttlefish processes remain"
  fi

  respond "Android virtual device stopped"
}

stop_cvd() {
  stop_cvd_internal false "$@"
}

reset_cvd() {
  stop_cvd_internal true "$@"
}

restart_cvd() {
  stop_cvd
  sleep 0.5
  start_cvd false "$@"
}

status_cvd() {
  local message
  if has_live_cvd_processes; then
    message="Android running."
  else
    message="Android not running."
  fi

  respond "${message}"
  printf '%s\n' "${message}" >&3
}

main() {
  local command="${1:-help}"

  case "${command}" in
    start)
      redirect_start_logs
      shift
      run_timed_operation "started" start_cvd false "$@"
      ;;
    startfs)
      redirect_start_logs
      shift
      run_timed_operation "started" start_cvd true "$@"
      ;;
    stop)
      redirect_stop_logs
      shift
      run_timed_operation "stopped" stop_cvd "$@"
      ;;
    reset)
      shift
      reset_cvd "$@"
      ;;
    restart)
      shift
      run_timed_operation "restarted" restart_cvd "$@"
      ;;
    status)
      shift
      status_cvd "$@"
      ;;
    help|-h|--help)
      usage
      usage 3
      ;;
    *)
      usage
      usage 3
      exit 1
      ;;
  esac
}

main "$@"
