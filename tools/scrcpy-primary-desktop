#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

usage() {
  cat <<'EOF'
Usage:
  scrcpy-primary-desktop [options] [-- scrcpy-args...]

Options:
  --serial SERIAL              ADB serial to use
  --desktop-size WxH[/DPI]     Override primary display size and optional DPI
  --no-turn-screen-off         Keep the primary display powered on
  --scrcpy-bin PATH            scrcpy client binary to run
  --server-path PATH           scrcpy-server jar to push
  -h, --help                   Show this help

Examples:
  tools/scrcpy-primary-desktop
  tools/scrcpy-primary-desktop --desktop-size 1600x1000/200
  tools/scrcpy-primary-desktop -- --fullscreen
EOF
}

die() {
  printf 'scrcpy-primary-desktop: %s\n' "$*" >&2
  exit 1
}

pick_first_executable() {
  local candidate
  for candidate in "$@"; do
    if [[ -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done
  return 1
}

pick_first_file() {
  local candidate
  for candidate in "$@"; do
    if [[ -f "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done
  return 1
}

pick_serial() {
  local devices
  mapfile -t devices < <(adb devices | awk 'NR > 1 && $2 == "device" { print $1 }')
  case "${#devices[@]}" in
    0) die "no adb devices found" ;;
    1) printf '%s\n' "${devices[0]}" ;;
    *) die "multiple adb devices found; pass --serial" ;;
  esac
}

parse_desktop_size() {
  local spec="$1"
  local size_part="${spec%%/*}"
  local dpi_part=""

  if [[ "${spec}" == */* ]]; then
    dpi_part="${spec#*/}"
  fi

  [[ "${size_part}" =~ ^[0-9]+x[0-9]+$ ]] \
    || die "invalid desktop size '${spec}'"

  DESKTOP_WIDTH="${size_part%x*}"
  DESKTOP_HEIGHT="${size_part#*x}"

  if [[ -n "${dpi_part}" ]]; then
    [[ "${dpi_part}" =~ ^[0-9]+$ ]] || die "invalid DPI '${dpi_part}'"
    DESKTOP_DPI="${dpi_part}"
  fi
}

adb_shell() {
  adb -s "${ADB_SERIAL}" shell "$@"
}

enable_desktop_mode_settings() {
  adb_shell settings put global enable_freeform_support 1
  adb_shell settings put global enable_non_resizable_multi_window 1
  adb_shell settings put global force_desktop_mode_on_external_displays 1
  adb_shell settings put global override_desktop_mode_features 1
}

apply_desktop_size() {
  adb_shell wm size "${DESKTOP_WIDTH}x${DESKTOP_HEIGHT}"
  if [[ -n "${DESKTOP_DPI}" ]]; then
    adb_shell wm density "${DESKTOP_DPI}"
  fi
  RESTORE_WM=true
}

cleanup() {
  if [[ "${RESTORE_WM}" == true ]]; then
    adb_shell wm size reset >/dev/null 2>&1 || true
    adb_shell wm density reset >/dev/null 2>&1 || true
  fi
}

ADB_SERIAL="${ADB_SERIAL:-}"
SCRCPY_BIN="${SCRCPY_BIN:-}"
SCRCPY_SERVER_PATH_OVERRIDE="${SCRCPY_SERVER_PATH:-}"
TURN_SCREEN_OFF=true
RESTORE_WM=false
DESKTOP_WIDTH=""
DESKTOP_HEIGHT=""
DESKTOP_DPI=""
SCRCPY_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --serial)
      [[ $# -ge 2 ]] || die "missing value for --serial"
      ADB_SERIAL="$2"
      shift 2
      ;;
    --desktop-size)
      [[ $# -ge 2 ]] || die "missing value for --desktop-size"
      parse_desktop_size "$2"
      shift 2
      ;;
    --desktop-size=*)
      parse_desktop_size "${1#*=}"
      shift
      ;;
    --no-turn-screen-off)
      TURN_SCREEN_OFF=false
      shift
      ;;
    --scrcpy-bin)
      [[ $# -ge 2 ]] || die "missing value for --scrcpy-bin"
      SCRCPY_BIN="$2"
      shift 2
      ;;
    --scrcpy-bin=*)
      SCRCPY_BIN="${1#*=}"
      shift
      ;;
    --server-path)
      [[ $# -ge 2 ]] || die "missing value for --server-path"
      SCRCPY_SERVER_PATH_OVERRIDE="$2"
      shift 2
      ;;
    --server-path=*)
      SCRCPY_SERVER_PATH_OVERRIDE="${1#*=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      SCRCPY_ARGS+=("$@")
      break
      ;;
    *)
      SCRCPY_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "${ADB_SERIAL}" ]]; then
  ADB_SERIAL="$(pick_serial)"
fi

if [[ -z "${SCRCPY_BIN}" ]]; then
  SCRCPY_BIN="$(
    pick_first_executable \
      "${REPO_ROOT}/out/verify-scrcpy/app/scrcpy" \
      /usr/lib/cuttlefish-common/bin/scrcpy \
      /usr/bin/scrcpy
  )" || die "could not find a scrcpy client binary"
fi

if [[ -z "${SCRCPY_SERVER_PATH_OVERRIDE}" ]]; then
  SCRCPY_SERVER_PATH_OVERRIDE="$(
    pick_first_file \
      "${REPO_ROOT}/out/build-scrcpy-server/scrcpy-server" \
      /usr/lib/cuttlefish-common/share/scrcpy/scrcpy-server \
      /usr/share/scrcpy/scrcpy-server
  )" || die "could not find a scrcpy-server jar"
fi

trap cleanup EXIT

enable_desktop_mode_settings

if [[ -n "${DESKTOP_WIDTH}" ]]; then
  apply_desktop_size
fi

if [[ "${TURN_SCREEN_OFF}" == true ]]; then
  SCRCPY_ARGS=(--turn-screen-off "${SCRCPY_ARGS[@]}")
fi

SCRCPY_ARGS=(--serial "${ADB_SERIAL}" "${SCRCPY_ARGS[@]}")

printf 'Using adb serial: %s\n' "${ADB_SERIAL}" >&2
printf 'Using scrcpy client: %s\n' "${SCRCPY_BIN}" >&2
printf 'Using scrcpy server: %s\n' "${SCRCPY_SERVER_PATH_OVERRIDE}" >&2
if [[ -n "${DESKTOP_WIDTH}" ]]; then
  printf 'Primary display override: %sx%s' "${DESKTOP_WIDTH}" "${DESKTOP_HEIGHT}" >&2
  if [[ -n "${DESKTOP_DPI}" ]]; then
    printf '/%s' "${DESKTOP_DPI}" >&2
  fi
  printf '\n' >&2
fi

SCRCPY_SERVER_PATH="${SCRCPY_SERVER_PATH_OVERRIDE}" exec "${SCRCPY_BIN}" "${SCRCPY_ARGS[@]}"
